# {KUNDE} {PRODUKT_NAME} — Konfigurations-VORLAGE
#
# >>> UMBENENNEN: Diese Datei heisst bewusst "env.example" (ohne Punkt), damit sie sichtbar in der
# >>> Vorlage liegt. Im echten Kunden-Repo den Backend-Block als "backend/.env" und den Frontend-Block
# >>> als "frontend/.env" ablegen (jeweils MIT fuehrendem Punkt) und Werte eintragen.
# >>> Ohne .env laeuft alles im Uebungs-Modus (MOCK_MODE). .env NIE einchecken (gehoert in .gitignore).

# ============================================================
# BACKEND  ->  nach  backend/.env
# ============================================================

# true = Probe-Daten ohne echten Schluessel (Standard), false = echte {ECHT_SYSTEM}-Anbindung
MOCK_MODE=true

# --- Anbindung an {ECHT_SYSTEM} (nur noetig bei MOCK_MODE=false) ---
# Adresse/Domain des Fremd-Systems, z.B. {ECHT_DOMAIN_BEISPIEL}
{ECHT_SYSTEM_DOMAIN_VAR}=
# Zugangs-Schluessel/Token aus dem Fremd-System (wie ein Haustuer-Schluessel — sicher behandeln)
{ECHT_SYSTEM_TOKEN_VAR}=
# Version der Fremd-Schnittstelle (falls versioniert)
{ECHT_SYSTEM_API_VERSION_VAR}={API_VERSION_DEFAULT}

# --- KI (Anthropic) — eigener Key PRO KUNDE, nie einen anderen Key wiederverwenden ---
ANTHROPIC_API_KEY=

# --- Login / Sicherheit ---
# Geheimnis zum Signieren der Login-Tokens (JWT) — in Produktion zwingend aendern!
JWT_SECRET=bitte-aendern-langes-zufalls-geheimnis
# PIN(s) fuer die Test-Nutzer (Mock-Standard: 0000; spaeter bcrypt-Hash moeglich)
PIN_{NUTZER_1}=0000
PIN_{NUTZER_2}=0000

# --- Browser-Zugriff (CORS) ---
# Erlaubte Frontend-Adressen, kommagetrennt
CORS_ORIGINS=http://localhost:{PORT_FRONTEND}

# --- Datenbank ---
# Leer = Standard-Wahl: SQLite-Datei backend/data/{DB_ECHT}. Spaeter austauschbar gegen Postgres,
# z.B. postgresql+asyncpg://nutzer:passwort@host/dbname. Uebungs-Modus nutzt eine getrennte DB
# ({DB_UEBUNG}), damit Probe-Daten nie den Echt-Bestand beruehren.
DATABASE_URL=

# ============================================================
# FRONTEND  ->  nach  frontend/.env
# ============================================================

# Adresse des Backends (Standard: lokaler Server auf Port {PORT_BACKEND})
VITE_API_URL=http://localhost:{PORT_BACKEND}

# ============================================================
# PLATZHALTER-LEGENDE
#   {KUNDE}/{PRODUKT_NAME}                Kunde + Produkt
#   {ECHT_SYSTEM}                         angebundenes Fremd-System (z.B. Shopify, GP Manager)
#   {ECHT_SYSTEM_DOMAIN_VAR} / _TOKEN_VAR / _API_VERSION_VAR
#                                         die konkreten Env-Namen des Fremd-Systems
#   {ECHT_DOMAIN_BEISPIEL} / {API_VERSION_DEFAULT}   Beispiel-Werte
#   {NUTZER_1}/{NUTZER_2}                 Login-Namen (GROSS im Env-Namen)
#   {PORT_BACKEND}/{PORT_FRONTEND}        Ports (Registry: kunden/UEBERSICHT.md)
#   {DB_ECHT}/{DB_UEBUNG}                 DB-Dateinamen je Modus
# ============================================================
